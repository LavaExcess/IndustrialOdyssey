		}
		{
			dependencies: [
				"33433A443B65D252"
				"36836AD948F96B9F"
				"53EC96FA0E7C4ED4"
			]
			description: ["Зачем беспокоиться о том, что именно перемещается, если можно перемещать всё сразу! &5Универсальные трубы&r ещё более «всеядны», чем &cэнергетические&r. Они могут перемещать &eпредметы&r, &bжидкости&r и &cэнергию&r."]
			id: "4FBAB3A0FBF8CE2F"
			rewards: [{
				count: 16
				id: "02B1975FE7F3C29A"
				item: "pipez:universal_pipe"
				type: "item"
			}]
			size: 1.1d
			tasks: [{
				id: "1E0BB9A36487B272"
				item: "pipez:universal_pipe"

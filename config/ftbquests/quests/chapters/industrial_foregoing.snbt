		}
		{
			dependencies: [
				"4F3EF1574F31A7E2"
				"418E57E34FFC19E1"
				"2E8E292ED596A104"
			]
			dependency_requirement: "one_started"
			description: [
				"Добыча первого эфира будет страшноватой."
				"Эфир получается бурением иссушителя с помощью жидкостной лазерной основы с фиолетовой линзой."
				""
				"Но не бойся, в Industrial Foregoing есть механизм, который тебе поможет: Камера стазиса. Она накладывает на любой сущность эффект замедления максимального уровня, так что призвать иссушителя на ней безопасно."
				""
				"Главное, не дай кончиться энергии — если питание отключится, тебе придётся сражаться с иссушителем."
			]
			id: "3CB7884B7B32CF00"
			rewards: [
				{
					exclude_from_claim_all: true
					id: "6E3CC9BCD9D5A921"

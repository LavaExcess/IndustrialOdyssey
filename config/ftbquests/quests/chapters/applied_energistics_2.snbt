					type: "random"
				}
				{
					count: 4
					id: "23CF85C632E944DC"
					item: "libraryferret:iron_coins_jtl"
					type: "item"
				}
			]
			shape: "rsquare"
			tasks: [{
				id: "52521FCD58B2FEF0"
				item: {
					Count: 1
					id: "ae2:item_storage_cell_1k"
					tag: { }
				}
				title: "Ячейка хранения предметов ME"
				type: "item"
			}]
			title: "Хранение предметов"
			x: 16.5d
			y: 1.5d
		}
		{
			dependencies: ["361CCBD353D6FF34"]
			description: ["Помимо обычных ячеек, можно также сделать ячейки для &bмассового хранения&f с помощью незерита.\\n\\nАддон &dMEGA Cells&f предлагает &bЯчейку массового хранения предметов&f, которая ограничена &oодним&r типом предмета, но может хранить практически &o&lбесконечное*&r количество этого типа. Перед использованием её нужно отфильтровать в Верстаке ячеек.\\n\\n*&oТехнически до «максимального long». Кто знает, тот поймёт."]
			id: "0F03E75CF79BADD7"
